# Local development defaults
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
AEGISAI_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# LLM Gateway Plane ops BFF (Control Room metrics only — not completions)
# Local:
# LLM_GATEWAY_OPS_URL=http://127.0.0.1:8100/v1/ops/metrics
# SEMANTIC_CACHE_OPS_URL=http://127.0.0.1:8101/v1/ops/metrics
# Render (live Control Room):
LLM_GATEWAY_OPS_URL=https://aegis-llm-gateway-api.onrender.com/v1/ops/metrics
SEMANTIC_CACHE_OPS_URL=https://aegis-semantic-cache-api.onrender.com/v1/ops/metrics
# When live plane is unreachable, Control Room shows illustrative demo metrics (default on)
LLM_PLANE_DEMO_FALLBACK=true

# Portfolio local persistence. In AWS, replace SQLite with RDS/Aurora Postgres adapters.
AEGISAI_DB_BACKEND=sqlite
AEGISAI_CONTROL_PLANE_DB_PATH=/tmp/aegisai-control-plane.sqlite
AEGISAI_DATABASE_URL=postgresql://user:pass@localhost:5432/aegisai
AEGISAI_VECTOR_DB_PATH=/tmp/aegisai-vector-memory.sqlite
AEGISAI_HTTP_CONNECTORS_FILE=services/api/data/http_connectors.json

# Auth (dev headers or OIDC bearer) — set ENFORCE_AUTH=true for production pilots
AEGISAI_AUTH_MODE=dev
AEGISAI_ENFORCE_AUTH=false
AEGISAI_REQUIRE_ROLES=false

# Pilot / production enforcement
AEGISAI_PILOT_MODE=false
AEGISAI_REQUIRE_EXECUTION_TOKEN=false
# Fail-closed pilot profile (set all true + postgres for Principal demos):
# AEGISAI_PILOT_MODE=true
# AEGISAI_ENFORCE_AUTH=true
# AEGISAI_REQUIRE_EXECUTION_TOKEN=true
# PRODUCTION_STRICT=true
# AEGISAI_DB_BACKEND=postgres
PRODUCTION_STRICT=false
# Okta / Azure AD JWKS (when AEGISAI_AUTH_MODE=oidc)
AEGISAI_OIDC_ISSUER=
AEGISAI_OIDC_JWKS_URI=
AEGISAI_OIDC_AUDIENCE=

# Design partners: use postgres as sole system of record
# AEGISAI_PILOT_MODE=true
# AEGISAI_DB_BACKEND=postgres
# AEGISAI_REQUIRE_EXECUTION_TOKEN=true
# AEGISAI_ENFORCE_AUTH=true
# AEGISAI_AUTH_MODE=oidc

# Signed audit packets (Assure) — local_hmac for demo, kms for production
AEGISAI_AUDIT_SIGNING_MODE=local_hmac
AEGISAI_AUDIT_SIGNING_KEY=change-me-in-production
AEGISAI_AUDIT_KMS_KEY_ID=
AEGISAI_EXECUTION_TOKEN_SECRET=change-me-in-production
AEGISAI_EXECUTION_TOKEN_TTL_SECONDS=300

# Policy engine: builtin | opa (requires opa CLI)
AEGISAI_POLICY_ENGINE=builtin
AEGISAI_OPA_POLICY_PATH=platform/policy/aegisai.rego

# Connectors & notifications
STRIPE_SECRET_KEY=
SLACK_APPROVAL_WEBHOOK_URL=
SLACK_CONTENT_WEBHOOK_URL=
SLACK_STOCK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_APPROVAL_CHANNEL=#aegisai-hitl
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Website Build deploy connectors (Render env)
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_BASE_BRANCH=main
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
RENDER_API_KEY=
RENDER_SERVICE_ID=

# Optional LLM provider. gemini = free tier; openai for production swap later.
AEGISAI_LLM_PROVIDER=gemini
AEGISAI_LLM_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
AEGISAI_LLM_TIMEOUT_SECONDS=20

# Optional observability adapters
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aegisai-agent-governance-control-plane

# Agent FinOps — real usage metering + budget enforcement for Website Build agents.
# Unset AGENTFINOPS_API_URL: FinOpsClient computes cost locally, never reports a
# breach (no persisted ledger to check against) — set it to get real enforcement.
AGENTFINOPS_API_URL=
AGENTFINOPS_API_KEY=
